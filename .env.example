# LLM Provider (groq / openai)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=moonshotai/kimi-k2-instruct-0905
GROQ_MAX_TOKENS=16384
GROQ_TEMPERATURE=0.7

# Telegram (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OCTO-FLOWS: SonarQube (optional — needed for code scan flow)
# 1. docker compose up -d
# 2. Login at http://localhost:9000 (admin/admin), change password
# 3. Generate token: My Account → Security → Generate Token
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=
SONAR_PROJECT_BASE_KEY=vec
SONAR_SCANNER_IMAGE=sonarsource/sonar-scanner-cli:latest
