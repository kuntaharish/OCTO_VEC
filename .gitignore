# Dependencies
node_modules/

# Environment — never commit secrets
.env
.env.local
.env.*.local

# Runtime data — generated at startup, not source
data/
!dashboard/src/data/
workspace/
/memory/

# Build output
dist/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
nul

# Claude session data
.claude/
.pi/

# User-specific profile files
ITS_ME.md
self.md

# SQLite WAL files (if any slip through)
*.db-shm
*.db-wal

# Internal TO-DOs — personal tracking, not source
TO-DOs/

# Tests — local smoke tests, not CI
tests/

# Mobile build artifacts
*.apk
*.aab
*.ipa
