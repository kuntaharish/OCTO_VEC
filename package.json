{
  "name": "octo-vec",
  "version": "2.0.0",
  "description": "OCTO VEC — Virtual Employed Company | AI Agent Orchestration Platform",
  "license": "MIT",
  "author": "Akhil",
  "keywords": [
    "ai",
    "agents",
    "autonomous",
    "workforce",
    "kanban",
    "dashboard"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "type": "module",
  "main": "./dist/tower.js",
  "bin": {
    "octo-vec": "./dist/tower.js"
  },
  "exports": {
    ".": "./dist/tower.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "core/",
    "dashboard/dist/"
  ],
  "scripts": {
    "start": "tsx src/tower.ts",
    "dev": "tsx --watch src/tower.ts",
    "typecheck": "tsc --noEmit",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:dashboard": "npm --prefix dashboard install && npm --prefix dashboard run build",
    "build": "npm run build:ts && npm run build:dashboard",
    "prepublishOnly": "npm run build",
    "dashboard:dev": "npm --prefix dashboard run dev"
  },
  "dependencies": {
    "@line/bot-sdk": "^10.6.0",
    "@mariozechner/pi-agent-core": "^0.53.1",
    "@mariozechner/pi-ai": "^0.54.0",
    "@mariozechner/pi-coding-agent": "^0.53.1",
    "@mattermost/client": "^11.4.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^4.6.0",
    "@types/ws": "^8.18.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^9.6.0",
    "commander": "^14.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "discord.js": "^14.25.1",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "grammy": "^1.40.0",
    "helmet": "^8.1.0",
    "irc-framework": "^4.14.0",
    "jsforce": "^3.10.14",
    "jsonwebtoken": "^9.0.3",
    "matrix-bot-sdk": "^0.8.0",
    "node-pty": "^1.1.0",
    "nostr-tools": "^2.23.3",
    "pdfkit": "^0.18.0",
    "pptxgenjs": "^4.0.1",
    "tmi.js": "^1.8.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.95",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.5",
    "gif-encoder-2": "^1.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
